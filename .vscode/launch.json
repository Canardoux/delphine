{
        "version": "0.2.0",
        "configurations": [
                {
                        "name": "Run Extension",
                        "type": "extensionHost",
                        "request": "launch",
                        "runtimeExecutable": "${execPath}",
                        "args": ["--extensionDevelopmentPath=${workspaceFolder}", "--remote-debugging-port=9222"],
                        "outFiles": ["${workspaceFolder}/out/**/*.js"],
                        "preLaunchTask": "npm: compile"
                },
                {
                        "name": "Attach Webview (Chrome)",
                        "type": "chrome",
                        "request": "attach",
                        "port": 9222,
                        "webRoot": "${workspaceFolder}",
                        "sourceMaps": true
                },
                {
                        "name": "Vite: debug zazaVue (Chrome)",
                        "type": "pwa-chrome",
                        "request": "launch",
                        "url": "http://localhost:5173/src/zazaVue.html",
                        "userDataDir": "${workspaceFolder}/.vscode/chrome-vite-profile",

                        // ✅ racine du repo Delphine (pas examples/zazaVue)
                        "webRoot": "${workspaceFolder}",

                        "sourceMaps": true,
                        "trace": false,

                        "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"],

                        "sourceMapPathOverrides": {
                                // --- Vite dev server direct URLs
                                "http://localhost:5173/src/*": "${workspaceFolder}/examples/zazaVue/src/*",
                                "/src/*": "${workspaceFolder}/examples/zazaVue/src/*",
                                "*/src/*": "${workspaceFolder}/examples/zazaVue/src/*",

                                // --- Vite virtual scheme variants
                                "vite:///src/*": "${workspaceFolder}/examples/zazaVue/src/*",
                                "vite://src/*": "${workspaceFolder}/examples/zazaVue/src/*",
                                "vite:///./src/*": "${workspaceFolder}/examples/zazaVue/src/*",

                                // --- Some stacks still emit webpack-style source URLs
                                "webpack:///src/*": "${workspaceFolder}/examples/zazaVue/src/*",
                                "webpack:///./src/*": "${workspaceFolder}/examples/zazaVue/src/*",

                                // --- Absolute FS exposure used by Vite (@fs)
                                "http://localhost:5173/@fs/*": "/*",
                                "/@fs/*": "/*",
                                "vite:///@fs/*": "/*",
                                "*/@fs/*": "/*",

                                // --- Fallback: if Vite emits vite:///<absolute path> (rare)
                                "vite:///*": "${workspaceFolder}/*"
                        }
                }
        ],
        "compounds": [
                {
                        "name": "Run + Attach Webview",
                        "configurations": ["Run Extension", "Attach Webview (Chrome)"]
                }
        ],
        "tasks": [
                {
                        "label": "Start Vite dev server (zazaVue)",
                        "type": "shell",
                        "command": "${workspaceFolder}/bin/preview-server.sh",
                        "isBackground": true,
                        "problemMatcher": [],
                        "presentation": { "reveal": "always" }
                }
        ]
}
